.env
.gemini/
.claude/
.psymew/
creds

# ---- Python build / cache artifacts ---------------------------------
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
build/
dist/
.pytest_cache/
.ruff_cache/

# ---- Virtual environments -------------------------------------------
.venv/
venv/

# ---- Editor / IDE noise ---------------------------------------------
.idea/
.vscode/

