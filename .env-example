# PsyMew configuration — see https://github.com/professor-conifer/PsyMew
# Easiest setup: run `python psymew_gui.py`
# Otherwise: copy this file to `.env` and fill in your values below.

# --- Pokemon Showdown account ----------------------------------------
PS_USERNAME=your_username
PS_PASSWORD=your_password
# PS_AVATAR=red

# --- Battle setup ----------------------------------------------------
# bot_mode: accept_challenge | challenge_user | search_ladder
PS_BOT_MODE=accept_challenge
PS_FORMAT=gen9randombattle
# PS_USER_TO_CHALLENGE=
# PS_ROOM_NAME=
# PS_TEAM_NAME=

# --- Showdown server (optional) --------------------------------------
# Defaults to the official server. Override these when using a mirror —
# for the PokéAgent Challenge ladder:
#   PS_WEBSOCKET_URI=wss://battling.pokeagentchallenge.com/showdown/websocket
#   PS_LOGIN_URI=https://battling.pokeagentchallenge.com/action.php?
# PS_WEBSOCKET_URI=
# PS_LOGIN_URI=

# --- AI decision engine ---------------------------------------------
# Choose one of: mcts | claude | gemini | deepseek
DECISION_ENGINE=claude

# Only fill in the API key for the engine you selected above.
# ANTHROPIC_API_KEY=
# GEMINI_API_KEY=
# DEEPSEEK_API_KEY=
