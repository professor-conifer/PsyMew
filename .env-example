# PsyMew Configuration
# Rename this file to .env or create your own .env file

PS_USERNAME=your_username
PS_PASSWORD=your_password

# Default Game Settings
PS_FORMAT=gen9randombattle
PS_BOT_MODE=accept_challenge

# Gemini API Keys (if not using Google OAuth)
# GEMINI_API_KEY=your_key_here

# Claude (alternative to Gemini)
DECISION_ENGINE=claude
